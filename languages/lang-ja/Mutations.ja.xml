<?xml version="1.0" encoding="utf-8" ?>
<mutations Lang="ja" LoadPriority="1000" Encoding="utf-8">
  <category Name="Morphotypes" DisplayName="▶{{W|Morphotypes}}" ExcludeFromPool="true">
    <mutation Name="Chimera" DisplayName="▶Chimera">
      <description>
        <p>▶You only manifest physical mutations, and all of your mutation choices when manifesting a new mutation are physical.</p>
        <br />
        <p>▶Whenever you manifest a new mutation, one of your choices will also cause you to grow a new limb at random.</p>
      </description>
      <leveltext></leveltext>
    </mutation>
    <mutation Name="Esper" DisplayName="▶Esper">
      <description>
        <p>▶You only manifest mental mutations, and all of your mutation choices when manifesting a new mutation are mental.</p>
      </description>
      <leveltext></leveltext>
    </mutation>
    <mutation Name="Unstable Genome" DisplayName="▶Unstable Genome">
      <description>
        <p>▶You gain one extra mutation each time you buy this, but the mutations don't manifest right away.</p>
        <p>▶Whenever you gain a level, there's a 33% chance that your genome destabilizes and you get to choose from 3 random mutations.</p>
      </description>
      <leveltext></leveltext>
    </mutation>
  </category>

  <category Name="Physical" DisplayName="▶{{G|Physical Mutations}}">
    <mutation Name="Adrenal Control" DisplayName="▶Adrenal Control" BearerDescription="▶those with control over their adrenal glands">
      <description>
        <p>▶You regulate your body's release of adrenaline.</p>
      </description>
      <leveltext>
        <p>▶You can increase your body's adrenaline flow for <stat Name="Duration" />.</p>
        <p>▶While it's flowing, you gain +<stat Name="QuicknessBonus" /> quickness and other physical mutations gain +<stat Name="MutationBonus" Unit="ランク" />.</p>         
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
      </leveltext>
    </mutation>
    <mutation Name="Beak" DisplayName="▶Beak" BearerDescription="▶those with beaks">
      <description>
        <p>▶Your face bears a sightly <stat Name="BeakName" />.</p>
        <br />
        <p>▶+1 Ego</p>
        <p>▶You occasionally peck at your opponents.</p>
        <p>▶+200 reputation with {{w|<vartext>=faction:Birds=</vartext>}}</p>
      </description>
      <leveltext></leveltext>
    </mutation>
    <mutation Name="Burrowing Claws" DisplayName="▶Burrowing Claws" BearerDescription="▶burrowers">
      <description>
        <!-- code will prefix this with "Burrowing Claws Claw" blueprints VariantDescription -->
        <p>▶You bear spade-like claws that can burrow through the earth.</p>
      </description>
      <leveltext>
        <p>▶<vartext>=weapon.Name=</vartext> penetration vs. walls: <stat Name="WallPenetration" /></p>
        <p>▶<vartext>=weapon.Name|pluralize=</vartext> destroy walls after <stat Name="WallHits" Unit="▶penetrating hit" />.</p>
        <switch Name="PrereleaseContent"><case Value="true"><p>▶Can dig passages up or down when outside of combat</p></case></switch>
        <p>▶<vartext>=weapon.Name|pluralize= are also a =weaponClass.name= class natural weapon that deal <stat Name="Damage" /> base damage to non-walls.</vartext></p>
      </leveltext>
    </mutation>
    <mutation Name="Carapace" DisplayName="▶Carapace" BearerDescription="▶the carapaced">
      <description>
        <!-- code will prefix this with blueprints VariantDescription -->
        <p>▶You are protected by a durable carapace.</p>
      </description>
      <leveltext>
        <p><stat Name="AV" Filters="signed" />ＡＶ</p>
        <p><stat Name="DV" Filters="signed" />ＤＶ</p>
        <p><stat Name="HeatResist" Filters="signed" />耐熱性</p>
        <p><stat Name="ColdResist" Filters="signed" />耐寒性</p>
        <switch Name="AddsRep"><case Value="" /><default><p>▶<stat Name="AddsRep" /></p></default></switch>
        <p>▶You may tighten your <stat Name="CarapaceName" /> to receive double the AV bonus at a -2 DV penalty as long as you remain still.</p>
        <p>▶Cannot wear body armor.</p>
      </leveltext>
    </mutation>
    <mutation Name="Corrosive Gas Generation" DisplayName="▶Corrosive Gas Generation" BearerDescription="▶those who expel corrosive gas">
      <description>
        <p>▶You release a burst of <stat Name="GasName" /> around yourself.</p>
      </description>
      <leveltext>
        <p>▶Releases gas for <stat Name="Duration" Unit="[周\ラウンド]" /></p>
        <switch Name="ExtraDescription"><case Value="" /><default><p><stat Name="ExtraDescription" /></p></default></switch>
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
      </leveltext>
    </mutation>
    <mutation Name="Double-muscled" DisplayName="▶Double-muscled" BearerDescription="▶the double-muscled">
      <description>
        <p>▶You are possessed of hulking strength.</p>
      </description>
      <leveltext>
        <p>+<stat Name="Strength" />筋力</p>
        <p>▶<stat Name="DazeChance" />% chance to daze your opponent on a successful melee attack for 2-3 rounds</p>
      </leveltext>
    </mutation>
    <mutation Name="Electrical Generation" DisplayName="▶Electrical Generation" BearerDescription="▶those who generate electricity">
      <description>
        <p>▶You accrue electrical charge that you can use and discharge to deal damage.</p>
      </description>
      <leveltext>
        <p>▶Maximum charge: <stat Name="MaxCharge" /></p>
        <p>▶Accrue base <stat Name="BaseChargePerTurn" /> charge per turn</p>
        <p>▶Can discharge all held charge for 1d4 damage per <stat Name="DischargeChunk" /> charge</p>
        <p>▶Discharge can arc to adjacent targets dealing reduced damage, up to 1 target per <stat Name="DischargeChunk" /> charge</p>
        <p>▶EMP causes involuntary discharge (difficulty 18 Willpower save)</p>
        <switch Name="CanDrinkTransient"><case Value="true"><p>▶You can drink change from electrical power sources.</p></case><default><p>▶You can drink charge from energy cells and capacitors.</p></default></switch>
        <p>▶You gain <stat Name="DamageAbsorbFactor" /> charge per point of electrical damage taken.</p>
        <p>▶You can provide charge to equipped devices that have integrated power systems.</p>
      </leveltext>
    </mutation>
    <mutation Name="Electromagnetic Pulse" DisplayName="▶Electromagnetic Pulse" BearerDescription="▶those who emit electromagnetic pulses">
      <description>
        <p>▶You generate an electromagnetic pulse that disables nearby artifacts and machines.</p>
      </description>
      <leveltext>
        <p>▶面積: <stat Name="Area" /> centered around yourself</p>
        <statline Name="Duration" DisplayName="期間" Unit="[周\ラウンド]" />
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
      </leveltext>
    </mutation>
    <mutation Name="Flaming Ray" DisplayName="▶Flaming Ray" BearerDescription="▶the flaming-handed">
      <description>
        <p>▶You emit a ray of flame<switch Name="BodyPartName"><case Value="" /><default> from your <stat Name="BodyPartName" /></default></switch>.</p>
      </description>
      <leveltext>
        <p>▶Emits a <stat Name="Range" />-square ray of flame in the direction of your choice.</p>
        <statline Name="Damage" DisplayName="ダメージ" />
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
        <p>▶Melee attacks heat opponents by <stat Name="HeatOnHit" Unit="度" /></p>
      </leveltext>
    </mutation>
    <mutation Name="Freezing Ray" DisplayName="▶Freezing Ray" BearerDescription="▶the frozen-handed">
      <description>
        <p>▶You emit a ray of frost<switch Name="BodyPartName"><case Value="" /><default> from your <stat Name="BodyPartName" /></default></switch>.</p>
      </description>
      <leveltext>
        <p>▶Emits a <stat Name="Range" />-square ray of frost in the direction of your choice.</p>
        <statline Name="Damage" DisplayName="ダメージ" />
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
        <p>▶Melee attacks cool opponents by <stat Name="CoolOnHit" Unit="度" /></p>
      </leveltext>
    </mutation>
    <mutation Name="Heightened Hearing" DisplayName="▶Heightened Hearing" BearerDescription="▶those with heightened hearing">
      <description>
        <p>▶You are possessed of unnaturally acute hearing.</p>
      </description>
      <leveltext>
        <p>▶You detect the presence of creatures within a radius of <stat Name="Radius" />.</p>
        <p><switch Name="LevelDiff"><case Value="1">▶{{rules|Increased chance to identify nearby detected creatures}}</case><default>▶Chance to identify nearby detected creatures</default></switch></p>
      </leveltext>
    </mutation>
    <mutation Name="Heightened Quickness" DisplayName="▶Heightened Quickness" BearerDescription="▶the quick">
      <description>
        <p>▶You are gifted with tremendous speed.</p>
      </description>
      <leveltext>
        <p>▶+<stat Name="SpeedBonus" /> Quickness</p>
      </leveltext>
    </mutation>
    <mutation Name="Horns" DisplayName="▶Horns" BearerDescription="▶the horned">
      <description>
        <p>▶<vartext>=horns.A.name.or.plural= =horns.verb:jut= out of your head.</vartext></p>
      </description>
      <leveltext>
        <p>▶20% chance on melee attack to gore your opponent</p>
        <statline Name="Damage" DisplayName="▶Damage increment" />
        <statline Name="ToHitBonus" DisplayName="▶To-hit bonus" />
        <switch Name="LevelMode">
          <case Value="BleedBonus"><p>▶{{rules|Increased bleeding save difficulty and intensity}}</p></case>
          <case Value="LevelUp"><p>▶{{rules|Increased bleeding save difficulty}}</p></case>
          <default><p>▶Goring attacks may cause bleeding</p></default>
        </switch>
        <p>▶<vartext>=horns.Name= =horns.verb:are= a short-blade class natural weapon.</vartext></p>
        <p>▶+<stat Name="AV" /> AV</p>
        <p>▶Cannot wear helmets</p>
        <p>▶+100 reputation with {{w|antelopes}} and {{w|goatfolk}}</p>
      </leveltext>
    </mutation>
    <mutation Name="Multiple Arms" DisplayName="▶Multiple Arms" BearerDescription="▶the many-armed" />
    <mutation Name="Multiple Legs" DisplayName="▶Multiple Legs" BearerDescription="▶the many-legged" />
    <mutation Name="Night Vision" DisplayName="▶Night Vision" BearerDescription="▶the darksighted" />
    <mutation Name="Phasing" DisplayName="▶Phasing" BearerDescription="▶those who phase" />
    <mutation Name="Photosynthetic Skin" DisplayName="▶Photosynthetic Skin" BearerDescription="▶the green-skinned" />
    <mutation Name="Quills" DisplayName="▶Quills" Exclusions="Carapace" BearerDescription="▶the quilled" />
    <mutation Name="Regeneration" DisplayName="▶Regeneration" BearerDescription="▶those who regenerate" />
    <mutation Name="Sleep Gas Generation" DisplayName="▶Sleep Gas Generation" BearerDescription="▶those who expel sleep gas">
      <description>
        <p>▶You release a burst of <stat Name="GasName" /> around yourself.</p>
      </description>
      <leveltext>
        <p>▶Releases gas for <stat Name="Duration" Unit="[周\ラウンド]" /></p>
        <switch Name="ExtraDescription"><case Value="" /><default><p><stat Name="ExtraDescription" /></p></default></switch>
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
      </leveltext>
    </mutation>
    <mutation Name="Slime Glands" DisplayName="▶Slime Glands" BearerDescription="▶slime spitters">
      <description>
        <p>▶You produce a viscous slime that you can spit at things.</p>
        <p></p>
        <p>▶Covers an area with slime</p>
        <statline Name="Range" DisplayName="射程" />
        <statline Name="Area" DisplayName="面積" />
        <statline Name="Cooldown" DisplayName="冷却期間" Unit="[周\ラウンド]" />
        <p>▶You can walk over slime without slipping.</p>
      </description>
      <leveltext />
    </mutation>
    <mutation Name="Spinnerets" DisplayName="▶Spinnerets" BearerDescription="▶web weavers" />
    <mutation Name="Stinger (Confusing Venom)" DisplayName="▶Stinger (Confusing Venom)" BearerDescription="▶those with stingers tipped with confusing venom" />
    <mutation Name="Stinger (Paralyzing Venom)" DisplayName="▶Stinger (Paralyzing Venom)" BearerDescription="▶those with stingers tipped with paralyzing venom" />
    <mutation Name="Stinger (Poisoning Venom)" DisplayName="▶Stinger (Poisoning Venom)" BearerDescription="▶those with stingers tipped with poisoning venom" />
    <mutation Name="Thick Fur" DisplayName="▶Thick Fur" BearerDescription="▶the thickly furred" />
    <mutation Name="Triple-jointed" DisplayName="▶Triple-jointed" BearerDescription="▶the triple-jointed" />
    <mutation Name="Two-headed" DisplayName="▶Two-headed" BearerDescription="▶the two-headed" />
    <mutation Name="Two-hearted" DisplayName="▶Two-hearted" BearerDescription="▶the two-hearted" />
    <mutation Name="Wings" DisplayName="▶Wings" BearerDescription="▶the winged" />
  </category>

  <category Name="PhysicalDefects" DisplayName="▶{{R|Physical Defects}}">
    <mutation Name="Albino" DisplayName="▶Albino" BearerDescription="▶albinos" />
    <mutation Name="Amphibious" DisplayName="▶Amphibious" BearerDescription="▶the amphibious" />
    <mutation Name="Brittle Bones" DisplayName="▶Brittle Bones" BearerDescription="▶the brittle-boned" />
