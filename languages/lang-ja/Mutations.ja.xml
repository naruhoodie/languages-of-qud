    <mutation Name="Carnivorous" DisplayName="▶Carnivorous" BearerDescription="▶the carnivorous" />
    <mutation Name="Cold-Blooded" DisplayName="▶Cold-Blooded" BearerDescription="▶the cold-blooded" />
    <mutation Name="Electromagnetic Impulse" DisplayName="▶Electromagnetic Impulse" BearerDescription="▶those who cannot control their electromagnetic pulses" />
    <mutation Name="Hooks for Feet" DisplayName="▶Hooks for Feet" BearerDescription="▶those with hooks for feet" />
    <mutation Name="Irritable Genome" DisplayName="▶Irritable Genome" BearerDescription="▶those with irritable genomes" />
    <mutation Name="Myopic" DisplayName="▶Myopic" BearerDescription="▶the myopic" />
