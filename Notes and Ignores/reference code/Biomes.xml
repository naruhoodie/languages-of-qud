            <adjective>rust-shrouded</adjective>
        </variant>
        <variant Name="Strong">
            <noun>rust bog</noun>
        </variant>
    </biome>
    <biome Name="Psychic">
        <class>PsychicBiome</class>
        <levelMapper Class="PsychicLevelMapper" />
    </biome>
</biomes>